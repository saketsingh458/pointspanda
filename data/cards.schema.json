{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PointsPandaAI Card Catalog",
  "description": "Schema for the US credit card catalog (data/cards.json)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "issuer", "annual_fee", "reward_currency", "ui_elements"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "issuer": { "type": "string" },
      "card_type": {
        "type": "string",
        "enum": ["consumer", "business"],
        "description": "High-level card type; used for strategy tie-breaking (e.g. consumer vs business)."
      },
      "annual_fee": { "type": "number" },
      "reward_currency": { "type": "string" },
      "anniversary_bonus": {
        "type": ["string", "null"]
      },
      "ui_elements": {
        "type": "object",
        "properties": {
          "image_url": { "type": "string" },
          "apply_url": { "type": "string", "format": "uri" },
          "benefits_list": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      "valuation": {
        "type": "object",
        "properties": {
          "cpp_nerdwallet": { "type": "number" },
          "cpp_pointsguy": { "type": "number" },
          "cpp_assumed": { "type": "number" },
          "cpp_bankrate": { "type": "number" },
          "cpp_creditkarma": { "type": "number" }
        },
        "additionalProperties": false
      },
      "welcome_offer": {
        "type": "object",
        "properties": {
          "points": { "type": "number" },
          "spend_requirement": { "type": "number" },
          "timeframe_months": { "type": "number" }
        },
        "additionalProperties": false
      },
      "statement_credits": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "amount", "deducts_from_eligible_spend", "frequency"],
          "properties": {
            "name": { "type": "string" },
            "amount": { "type": "number" },
            "deducts_from_eligible_spend": { "type": "boolean" },
            "frequency": {
              "type": "string",
              "anyOf": [
                {
                  "enum": [
                    "monthly",
                    "quarterly",
                    "yearly",
                    "semi_annual",
                    "one_time",
                    "per_instance"
                  ]
                },
                {
                  "pattern": "^every_[1-9][0-9]*_years$"
                }
              ]
            },
            "restrictions": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "transfer_partners": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "ratio"],
          "properties": {
            "name": { "type": "string" },
            "ratio": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "points_transfer_eligibility": {
        "type": "string",
        "enum": ["direct", "pooling_only", "none"]
      },
      "transfer_eligibility_note": { "type": "string" },
      "perks_and_protections": {
        "type": "object",
        "required": ["lounge_access", "elite_status", "travel_insurances", "consumer_protections"],
        "properties": {
          "lounge_access": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                { "type": "object" }
              ]
            }
          },
          "elite_status": {
            "type": "array",
            "items": { "type": "string" }
          },
          "travel_insurances": {
            "type": "array",
            "items": { "type": "string" }
          },
          "consumer_protections": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      "higher_tier_benefits": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["benefit_name", "description", "unlock_requirement"],
          "properties": {
            "benefit_name": { "type": "string" },
            "description": { "type": "string" },
            "unlock_requirement": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "multipliers": {
        "type": "object",
        "required": ["base_rate"],
        "properties": {
          "base_rate": { "type": "number" },
          "categories": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["rate"],
              "properties": {
                "rate": { "type": "number" },
                "requires_portal": { "type": "boolean" },
                "cap_amount": { "type": "number" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "oneOf": [
      {
        "required": ["multipliers"],
        "properties": {
          "ui_elements": {
            "not": {
              "required": ["benefits_list"]
            }
          }
        }
      },
      {
        "not": {
          "required": ["multipliers"]
        },
        "properties": {
          "ui_elements": {
            "required": ["benefits_list"]
          }
        }
      }
    ],
    "additionalProperties": false
  }
}
